{
  "manifest_version": 3,
  "name": "Competitive Programming Browser Adapter",
  "version": "0.0.1",
  "description": "Browser Adapter for Competitive Programming Automation CLI",
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Competitive Programming Browser Adapter"
  },
  "host_permissions": ["ws://127.0.0.1:8684/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_idle",
      "js": ["content-script.js"]
    }
  ]
}
